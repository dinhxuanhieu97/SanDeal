{
  "name": "san-deal",
  "version": "1.0.0",
  "description": "Săn Deal - Chuyển link Shopee, tự động gắn affiliate & săn voucher",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test test/unit.test.mjs test/api.test.mjs test/ratelimit.test.mjs test/seo.test.mjs test/product.test.mjs test/chaos.test.mjs",
    "test:unit": "node --test test/unit.test.mjs",
    "test:api": "node --test test/api.test.mjs",
    "test:e2e": "node --test test/e2e.spec.mjs test/a11y.axe.mjs test/responsive.spec.mjs",
    "test:visual": "node --test test/visual.spec.mjs",
    "test:e2e:firefox": "PW_BROWSER=firefox node --test test/e2e.spec.mjs test/a11y.axe.mjs test/responsive.spec.mjs",
    "test:e2e:webkit": "PW_BROWSER=webkit node --test test/e2e.spec.mjs test/a11y.axe.mjs test/responsive.spec.mjs",
    "test:e2e:all": "npm run test:e2e && npm run test:e2e:firefox && npm run test:e2e:webkit",
    "perf": "node scripts/perf.mjs"
  },
  "keywords": [
    "shopee",
    "affiliate",
    "voucher",
    "deal",
    "cashback"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "autocannon": "^8.0.0",
    "axe-core": "^4.12.1",
    "pixelmatch": "^7.2.0",
    "playwright": "^1.61.1",
    "pngjs": "^7.0.0"
  }
}
