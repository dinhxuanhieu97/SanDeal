# ==== CẤU HÌNH SĂN DEAL ====
# Copy file này thành ".env" rồi điền thông tin của bạn.

# Cổng chạy server local
PORT=3000

# --- Shopee Affiliate ---
# Sub ID (nhãn theo dõi) — bắt buộc để tiền hoàn về đúng, đặt tuỳ ý, ví dụ: sandeal
SHOPEE_SUB_ID=sandeal

# Thông tin Shopee Affiliate Open API (LẤY TỪ affiliate.shopee.vn > API).
# Nếu để trống, site chạy ở "DEMO MODE": chỉ gắn tham số sub_id vào link
# để bạn test local. Khi có credentials thật, hệ thống sẽ tạo shortlink chính thức.
SHOPEE_APP_ID=
SHOPEE_APP_SECRET=
