{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    { "source": "/api/convert", "destination": "/api/index" },
    { "source": "/api/product", "destination": "/api/index" },
    { "source": "/api/health", "destination": "/api/index" },
    { "source": "/api/deals", "destination": "/api/index" },
    { "source": "/huong-dan-su-dung", "destination": "/huong-dan-su-dung.html" },
    { "source": "/san-sale", "destination": "/deals.html" },
    { "source": "/blog", "destination": "/blog.html" },
    { "source": "/blog/top-noi-chien-khong-dau", "destination": "/blog/top-noi-chien-khong-dau.html" },
    { "source": "/blog/ma-giam-gia-shopee-hom-nay", "destination": "/blog/ma-giam-gia-shopee-hom-nay.html" },
    { "source": "/blog/review-serum-vitamin-c", "destination": "/blog/review-serum-vitamin-c.html" },
    { "source": "/blog/do-so-sinh-can-mua", "destination": "/blog/do-so-sinh-can-mua.html" },
    { "source": "/blog/may-xay-cam-tay-loai-nao-tot", "destination": "/blog/may-xay-cam-tay-loai-nao-tot.html" },
    { "source": "/blog/kem-chong-nang-cho-da-dau", "destination": "/blog/kem-chong-nang-cho-da-dau.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options", "value": "SAMEORIGIN" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" }
      ]
    },
    {
      "source": "/(.*)\\.(css|js|svg|png|jpg|jpeg|webp|ico|woff2)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    },
    {
      "source": "/(sitemap\\.xml|robots\\.txt|site\\.webmanifest)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600" }
      ]
    }
  ]
}
